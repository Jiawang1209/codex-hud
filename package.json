{
  "name": "codex-hud",
  "version": "0.1.0",
  "description": "Real-time terminal HUD for Codex CLI and Agent CLI sessions.",
  "type": "module",
  "bin": {
    "codex-hud": "./dist/index.js"
  },
  "files": [
    "dist/",
